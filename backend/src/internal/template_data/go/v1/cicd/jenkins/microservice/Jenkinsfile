```groovy
pipeline {
    agent any

    parameters {
        string(
            name: 'RUN_ID',
            defaultValue: '',
            description: 'Platform pipeline run ID (passed by platform when triggering)'
        )
        booleanParam(
            name: 'ROLLBACK',
            defaultValue: false,
            description: 'Enable rollback'
        )
        string(
            name: 'ROLLBACK_VERSION',
            defaultValue: '',
            description: 'Version to rollback to'
        )
    }

    environment {
        PLATFORM_URL     = "http://platform.buyforu.run.place/api"
        PLATFORM_API_KEY = credentials('PLATFORM_API_KEY')
        RUN_ID           = "${params.RUN_ID}"
    }

    stages {

        stage('Checkout') {
            steps {
                script {
                    notifyStage('Checkout', 'running', 'Starting checkout...')

                    try {
                        checkout scm
                        notifyStage('Checkout', 'success', "Checked out branch ${env.BRANCH_NAME}")
                    } catch (err) {
                        notifyStage('Checkout', 'failed', "Checkout failed: ${err.getMessage()}")
                        throw err
                    }
                }
            }
        }

        stage('Setup') {
            steps {
                script {
                    notifyStage('Setup', 'running', 'Loading project configuration...')

                    try {

                        if (!fileExists('config.json')) {
                            error "config.json file not found!"
                        }

                        def projectConfig = readJSON file: 'config.json'
                        echo "Loaded Config: ${projectConfig}"

                        env.SERVICE_NAME = projectConfig.serviceName ?: error("serviceName missing in config.json")
                        env.GITHUB_REPO  = projectConfig.repoUrl ?: "not-defined"

                        echo "SERVICE_NAME = ${env.SERVICE_NAME}"

                        if (env.BRANCH_NAME == 'dev') {
                            env.ENVIRONMENT = 'dev'
                        } else if (env.BRANCH_NAME == 'test') {
                            env.ENVIRONMENT = 'test'
                        } else if (env.BRANCH_NAME in ['main','master']) {
                            env.ENVIRONMENT = 'prod'
                        } else {
                            error "Unsupported branch: ${env.BRANCH_NAME}"
                        }

                        echo "ENVIRONMENT = ${env.ENVIRONMENT}"

                        notifyStage('Setup', 'success',
                            "Service=${env.SERVICE_NAME} Environment=${env.ENVIRONMENT}")

                    } catch (err) {
                        notifyStage('Setup', 'failed', "Setup failed: ${err.getMessage()}")
                        throw err
                    }
                }
            }
        }

        stage('Build') {
            when {
                expression { !params.ROLLBACK }
            }

            steps {
                script {

                    notifyStage('Build', 'running', 'Generating version and building...')

                    try {

                        env.COMMIT_SHA = sh(
                            script: "git rev-parse --short HEAD",
                            returnStdout: true
                        ).trim()

                        def randomNum = new Random().nextInt(9000) + 1000
                        env.VERSION = "myservice/${env.SERVICE_NAME}-${env.COMMIT_SHA}-${randomNum}"

                        echo "Generated VERSION=${env.VERSION}"

                        sh "echo 'Simulating build...' && sleep 5 && echo 'Build complete'"

                        notifyStage('Build', 'success',
                            "Built version ${env.VERSION} successfully")

                    } catch (err) {

                        notifyStage('Build', 'failed',
                            "Build failed: ${err.getMessage()}")
                        throw err
                    }
                }
            }
        }

        stage('Test') {
            when {
                expression { !params.ROLLBACK }
            }

            steps {
                script {

                    notifyStage('Test', 'running', 'Running tests...')

                    try {

                        sh "echo 'Running unit tests...' && sleep 4 && echo 'All tests passed'"

                        notifyStage('Test', 'success',
                            'All tests passed')

                    } catch (err) {

                        notifyStage('Test', 'failed',
                            "Tests failed: ${err.getMessage()}")
                        throw err
                    }
                }
            }
        }

        stage('Push Image') {
            when {
                expression { !params.ROLLBACK }
            }

            steps {
                script {

                    notifyStage('Push Image', 'running',
                        'Pushing docker image to registry...')

                    try {

                        sh "echo 'Pushing image ${env.VERSION}...' && sleep 6 && echo 'Image pushed'"

                        notifyStage('Push Image', 'success',
                            "Pushed ${env.VERSION} to registry")

                    } catch (err) {

                        notifyStage('Push Image', 'failed',
                            "Image push failed: ${err.getMessage()}")
                        throw err
                    }
                }
            }
        }

        stage('Deploy') {

            when {
                expression { !params.ROLLBACK }
            }

            steps {
                script {

                    notifyStage('Deploy', 'running',
                        "Deploying ${env.VERSION} to ${env.ENVIRONMENT}...")

                    try {

                        sh "echo '🚀 Deploying ${env.VERSION} to ${env.ENVIRONMENT}' && sleep 5 && echo 'Deploy complete'"

                        notifyStage('Deploy', 'success',
                            "Deployed ${env.VERSION} to ${env.ENVIRONMENT} successfully")

                    } catch (err) {

                        notifyStage('Deploy', 'failed',
                            "Deploy failed: ${err.getMessage()}")
                        throw err
                    }
                }
            }
        }

        stage('Rollback') {

            when {
                allOf {
                    expression { params.ROLLBACK }
                    expression { params.ROLLBACK_VERSION?.trim() }
                }
            }

            steps {
                script {

                    notifyStage('Deploy', 'running',
                        "Rolling back to ${params.ROLLBACK_VERSION} on ${env.ENVIRONMENT}...")

                    try {

                        env.VERSION = params.ROLLBACK_VERSION

                        sh "echo '🔄 Rolling back to ${env.VERSION}' && sleep 5 && echo 'Rollback complete'"

                        notifyStage('Deploy', 'success',
                            "Rolled back to ${env.VERSION} on ${env.ENVIRONMENT} successfully")

                    } catch (err) {

                        notifyStage('Deploy', 'failed',
                            "Rollback failed: ${err.getMessage()}")
                        throw err
                    }
                }
            }
        }

        stage('Health Check') {
            steps {
                script {

                    notifyStage('Health Check', 'running',
                        'Running health checks...')

                    try {

                        sh "echo 'Checking service health...' && sleep 3 && echo 'Service is healthy'"

                        notifyStage('Health Check', 'success',
                            'All health checks passed. Service is live.')

                    } catch (err) {

                        notifyStage('Health Check', 'failed',
                            "Health check failed — service may be down: ${err.getMessage()}")
                        throw err
                    }
                }
            }
        }
    }

    post {

        success {
            script {

                def actionType = params.ROLLBACK ? "rollback" : "deploy"

                sh """
                    curl -s -X POST ${env.PLATFORM_URL}/artifacts \
                        -H "Content-Type: application/json" \
                        -H "X-API-Key: ${env.PLATFORM_API_KEY}" \
                        -d '{
                            "serviceName":  "${env.SERVICE_NAME}",
                            "environment":  "${env.ENVIRONMENT}",
                            "version":      "${env.VERSION}",
                            "artifactType": "docker",
                            "commitSha":    "${env.COMMIT_SHA ?: ''}",
                            "pipeline":     "jenkins",
                            "action":       "${actionType}",
                            "status":       "success"
                        }'
                """
            }
        }

        failure {
            script {

                def actionType = params.ROLLBACK ? "rollback" : "deploy"

                sh """
                    curl -s -X POST ${env.PLATFORM_URL}/artifacts \
                        -H "Content-Type: application/json" \
                        -H "X-API-Key: ${env.PLATFORM_API_KEY}" \
                        -d '{
                            "serviceName":  "${env.SERVICE_NAME}",
                            "environment":  "${env.ENVIRONMENT}",
                            "version":      "${env.VERSION ?: 'unknown'}",
                            "artifactType": "docker",
                            "commitSha":    "${env.COMMIT_SHA ?: ''}",
                            "pipeline":     "jenkins",
                            "action":       "${actionType}",
                            "status":       "failed"
                        }'
                """
            }
        }
    }
}

def notifyStage(String stageName, String status, String logs = '') {

    if (!env.RUN_ID?.trim()) {
        echo "[PLATFORM] RUN_ID not set — skipping stage notification"
        return
    }

    def safeLogs = logs.replace("'", "\\'")

    sh """
        curl -s -X POST ${env.PLATFORM_URL}/pipeline/${env.RUN_ID}/stage \
            -H "X-API-Key: ${env.PLATFORM_API_KEY}" \
            -H "Content-Type: application/json" \
            -d '{"stageName":"${stageName}","status":"${status}","logs":"${safeLogs}"}'
    """
}
```
